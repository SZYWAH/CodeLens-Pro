{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeLens Pro Next",
  "version": "1.1.0",
  "identifier": "com.szywah.codelensnext",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../web",
    "beforeBuildCommand": "npm run build --prefix ../web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CodeLens Pro Next",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "SZYWAH",
    "icon": ["icons/icon.ico"],
    "shortDescription": "本地优先的代码审查与项目理解桌面工具",
    "longDescription": "CodeLens Pro Next 提供代码审查、项目依赖图谱、AI 对话与学习材料沉淀。",
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false,
        "compression": "lzma",
        "startMenuFolder": "CodeLens Pro Next",
        "installerHooks": "windows/hooks.nsh"
      }
    }
  }
}
