# Docker Compose reads this file only after you copy it to .env
# Docker mode uses an internal MySQL host named "mysql"; do not use 127.0.0.1 in DATABASE_URL.

MYSQL_ROOT_PASSWORD=codelens_root_password
MYSQL_DATABASE=codelens_demo

# Host ports. Defaults avoid conflicts with local dev ports 5173/8000/3306.
FRONTEND_PORT=15173
BACKEND_PORT=18000
MYSQL_PORT=13307

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash
DEEPSEEK_DEFAULT_MODEL_LABEL=DeepSeek-V4-Flash
CODELENS_DEFAULT_LANGUAGE=Python
