# Copy this file to .env and fill in your local values.

# MySQL80 is expected to run locally. Keep the password out of source code.
DATABASE_URL=mysql+pymysql://root:YOUR_MYSQL_ROOT_PASSWORD@127.0.0.1:3306/codelens_demo?charset=utf8mb4

# DeepSeek uses an OpenAI-compatible API.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash
DEEPSEEK_DEFAULT_MODEL_LABEL=DeepSeek-V4-Flash
CODELENS_DEFAULT_LANGUAGE=Python
